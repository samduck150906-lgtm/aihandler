# ── Supabase (Required) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Paddle Payments (Required) ────────────────────────────
# Get these from: https://dashboard.paddle.com/settings/project
NEXT_PUBLIC_PADDLE_TOKEN=ctk_live_xxxxx  # Client-side token (from Paddle dashboard: Authentication > Client-side tokens)
NEXT_PUBLIC_PADDLE_PRICE_COINS_50=pri_xxxxx     # Price ID for 50 coins (one-time)
NEXT_PUBLIC_PADDLE_PRICE_COINS_200=pri_xxxxx    # Price ID for 200 coins (one-time)
NEXT_PUBLIC_PADDLE_PRICE_COINS_500=pri_xxxxx    # Price ID for 500 coins (one-time)
NEXT_PUBLIC_PADDLE_PRICE_PRO_MONTHLY=pri_xxxxx  # Price ID for Pro monthly plan (recurring)
PADDLE_API_KEY=pdl_live_xxxxx                   # Server-side API key (from Paddle dashboard: Authentication > API keys)
PADDLE_WEBHOOK_SECRET=pdl_whsec_xxxxx           # Webhook secret (from Paddle dashboard: Webhooks)
PADDLE_PRICE_COINS_MAP={"pri_xxxxx":50,"pri_yyyyy":200,"pri_zzzzz":500}  # JSON mapping of price IDs to coin amounts

# ── Admin Emails (Server-side only) ───────────────────────
# Comma-separated list of admin email addresses. NEVER expose in client code.
# Only used in Netlify Functions (check-admin.js, paddle-webhook.js)
ADMIN_EMAILS=admin@example.com,support@example.com

# ── Rate Limiting (Optional) ──────────────────────────────
# If not set, rate limiting uses in-memory storage (dev only)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...
# RATE_LIMIT_PER_MINUTE=10
# RATE_LIMIT_PER_DAY=100

# ── Google Analytics 4 (Optional) ─────────────────────────
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ── OpenAI (Currently unused, for future API integration) ──
# OPENAI_API_KEY=sk-proj-xxxxx
