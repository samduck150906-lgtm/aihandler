generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(uuid())
  provider      String          // "kakao", "google", "apple"
  snsId         String          @unique
  nickname      String?
  churuCount    Int             @default(10) // 웰컴 츄르 10개

  payments      Payment[]
  histories     UsageHistory[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Payment {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String

  orderId       String   @unique
  paymentKey    String?  @unique
  amount        Int
  churuAdded    Int      @default(25)
  status        String   // "READY", "DONE", "CANCELED"

  createdAt     DateTime @default(now())
}

model UsageHistory {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String

  roomType      String   // "REPLY", "WHATWASIT", "DEOKFLIX", "FINGER", "GOLAPING", "NYANGSHOPPER"
  cost          Int
  promptData    Json
  resultData    Json

  createdAt     DateTime @default(now())
}

// 익명 사용자 세션 (비로그인 시 츄르 잔액 서버 관리)
model AnonymousSession {
  id         String   @id @default(uuid())
  sessionId  String   @unique  // 쿠키에 담는 UUID
  churuCount Int      @default(10)  // 체험 10개
  clientIp   String?  // 체험 중복 방지용 (같은 IP에서 N개 초과 시 0개 지급)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 익명 결제 기록 (orderId 기반 복구 및 중복 처리)
model AnonymousPayment {
  id          String   @id @default(uuid())
  orderId     String   @unique
  sessionId   String   // AnonymousSession.sessionId
  paymentKey  String?
  amount      Int
  churuAdded  Int      @default(25)
  status      String   // "DONE", "CANCELED"
  createdAt   DateTime @default(now())
}
