{
  "compilerOptions": {
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./*"] }
  },
  "include": [
    "next-env.d.ts",
    "types/**/*.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "lib/**/*.ts",
    "hooks/**/*.ts",
    "*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "samdeok-mansion", "**/samdeok-mansion/**", "samdeok-mansion/backend/**", "samdeok-mansion/frontend/**"]
}
